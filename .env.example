# Default local demo mode
TRAKINDO_DATABASE_URL=sqlite:///data/trakindo_showcase/trakindo_demo.db
TRAKINDO_SQL_ROW_LIMIT=200
TRAKINDO_DEMO_SEED=42

# Optional local PostgreSQL mode
POSTGRES_DB=trakindo_showcase
POSTGRES_USER=trakindo
POSTGRES_PASSWORD=trakindo_demo
# Example:
# TRAKINDO_DATABASE_URL=postgresql+psycopg://trakindo:trakindo_demo@localhost:5432/trakindo_showcase

